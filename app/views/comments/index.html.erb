

<div class="flex items-center justify-between gap-3">
  <div>
    <h1 class="text-2xl font-bold"><%= Comment.model_name.human(count: 2) %></h1>
    <p class="text-sm text-slate-600">Turbo list updates + modal/drawer create/edit.</p>
  </div>

  <%= turbo_crud_modal_link "New", new_comment_path,
    class: "rounded-xl bg-slate-900 px-4 py-2 text-sm font-semibold text-white" %>
</div>

<div class="mt-6 space-y-3" id="<%= turbo_list_id(Comment) %>">
  <%= render partial: "comments/row", collection: @comments, as: :comment %>
</div>
